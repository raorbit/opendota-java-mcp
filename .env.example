# Copy to .env (gitignored) and fill in. Consumed by docker-compose.yml for the sidecar.

# OpenDota API key (optional). With a key: 300 req/min, no daily cap; keyless: 60/min, 3000/day.
# The sidecar holds the key so forwarding agents don't need it. Leave blank to run keyless.
OPENDOTA_API_KEY=

# Shared secret gating /api and /stats. REQUIRED for the compose setup: the sidecar binds
# 0.0.0.0 and joins a docker network, so the token is the only thing protecting the API key
# from other containers. Generate one with:  openssl rand -hex 32
# This is enforced: `docker compose up` refuses to start if it is unset/empty, and the sidecar
# itself refuses a non-loopback bind without one. Confirm "auth=true" in the startup log.
OPENDOTA_SIDECAR_TOKEN=

# Watched players: permanently archive every match these players appear in (needs the L2 cache,
# OPENDOTA_SIDECAR_L2=true). Comma-separated Steam32 account_ids; resolve names with search_players
# first. Leave blank to disable the archive.
OPENDOTA_SIDECAR_L2_WATCHED_PLAYERS=

# Retention budget for the watched archive, separate from the main cache cap. Blank, 0, or
# "unlimited"/"none"/"never" = never delete; a positive number is a hard limit (oldest evict first).
OPENDOTA_SIDECAR_L2_WATCHED_MAX_ROWS=
OPENDOTA_SIDECAR_L2_WATCHED_MAX_BYTES=

# How long (ms) an unparsed archived match is served from L2 before re-checking upstream for the
# parsed body. Blank = 1h. 0 = re-fetch on every access. (Advanced; leave blank for most setups.)
OPENDOTA_SIDECAR_L2_WATCHED_REFETCH_MILLIS=
